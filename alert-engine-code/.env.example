# ============================================================
# PRODAFLT Alert Engine — Environment Configuration
# NEVER commit real tokens. Copy to .env and fill in values.
# ============================================================

# Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:___PASTE_PASSWORD_HERE___@ep-bitter-waterfall-ajf1xpzc-pooler.c-3.us-east-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Telegram Bot (Alert Notifier)
TELEGRAM_BOT_TOKEN=___PASTE_BOT_TOKEN_HERE___
TELEGRAM_ADMIN_CHAT_ID=___PASTE_ADMIN_CHAT_ID_HERE___

# Alert Engine Settings
ALERT_ENGINE_INTERVAL_SECONDS=300
MIN_SPEND_FOR_ALERT_USD=20.0
MIN_CLICKS_FOR_ALERT=10
MIN_INSTALLS_FOR_ALERT=3

# Thresholds (USD)
THRESHOLD_CPC_KILL=2.5
THRESHOLD_CPI_KILL=5.0
THRESHOLD_UEPC_KILL=8.0
THRESHOLD_UEPC_SCALE=4.0
THRESHOLD_ROI_KILL=-0.5

# Confidence tuning
CONFIDENCE_HIGH_SAMPLE_MIN_SPEND=100.0
CONFIDENCE_HIGH_SAMPLE_MIN_CLICKS=50
CONFIDENCE_HIGH_SAMPLE_MIN_INSTALLS=10

# Logging
LOG_LEVEL=INFO
