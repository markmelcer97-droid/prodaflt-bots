# ============================================================
# PRODAFLT Parser Bot — Environment Configuration
# NEVER commit real tokens. Copy to .env and fill values.
# ============================================================

# Neon PostgreSQL
DATABASE_URL=___PASTE_DATABASE_URL_HERE___

# Telegram Bot Token (from @BotFather)
PARSER_BOT_TOKEN=___PASTE_BOT_TOKEN_HERE___

# Group chat ID where parser listens (use @getidsbot to find)
TARGET_GROUP_ID=___PASTE_GROUP_ID_HERE___

# Admin Telegram IDs (comma-separated) for /stats, /flush commands
ADMIN_IDS=___PASTE_ADMIN_IDS_HERE___

# Batch settings
BATCH_SIZE=10
BATCH_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# Optional: Sentry for error tracking
SENTRY_DSN=___OPTIONAL_SENTRY_DSN_HERE___
