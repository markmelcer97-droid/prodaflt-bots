# ============================================================
# PRODAFLT — .gitignore
# ============================================================

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
secrets/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.dmypy.json
.dmypy.json
.coverage
htmlcov/
.tox/
.venv/
venv/
env/
ENV/

# ---- IDEs ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---- Logs ----
logs/*.log
logs/*.log.*
!logs/.gitkeep

# ---- Database ----
*.db
*.sqlite
*.sqlite3

# ---- Docker ----
.dockerignore
docker-compose.override.yml

# ---- OS ----
Thumbs.db
.DS_Store
