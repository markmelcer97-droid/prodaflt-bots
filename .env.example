# ============================================
# PRODAFLT — Environment Template
# ============================================
# 1. Copy this file to `.env`
# 2. Fill in real values
# 3. NEVER commit `.env` to git!

# --- Neon PostgreSQL ---
DATABASE_URL=___PASTE_NEON_DATABASE_URL_HERE___

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- Kimi API (Moonshot) ---
KIMI_API_KEY=___PASTE_KIMI_API_KEY_HERE___
KIMI_API_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-7

# --- Telegram Bot Tokens ---
ROUTER_BOT_TOKEN=___PASTE_ROUTER_BOT_TOKEN_HERE___
RESEARCHER_BOT_TOKEN=___PASTE_RESEARCHER_BOT_TOKEN_HERE___
CREATIVE_BOT_TOKEN=___PASTE_CREATIVE_BOT_TOKEN_HERE___
META_BOT_TOKEN=___PASTE_META_BOT_TOKEN_HERE___
DATA_BOT_TOKEN=___PASTE_DATA_BOT_TOKEN_HERE___
TECH_BOT_TOKEN=___PASTE_TECH_BOT_TOKEN_HERE___
PARSER_BOT_TOKEN=___PASTE_PARSER_BOT_TOKEN_HERE___

# --- Telegram Chat IDs ---
ADMIN_CHAT_ID=___PASTE_ADMIN_CHAT_ID_HERE___
GROUP_CHAT_ID=___PASTE_GROUP_CHAT_ID_HERE___

# --- Parser Bot Config ---
PARSER_BATCH_SIZE=10
PARSER_BATCH_TIMEOUT=30
PARSER_REQUIRE_MENTION=false

# --- Alert Engine Thresholds ---
ALERT_KILL_CPI=5.0
ALERT_KILL_CPC=2.5
ALERT_KILL_UEPC=8.0
ALERT_KILL_ROI=-50.0
ALERT_SCALE_UEPC=4.0
ALERT_WATCH_UEPC_MIN=6.0
ALERT_WATCH_UEPC_MAX=8.0
ALERT_MIN_SPEND=20.0
ALERT_MIN_CLICKS=10

# --- YouTube API ---
YOUTUBE_API_KEY=___PASTE_YOUTUBE_API_KEY_HERE___

# --- Meta Ads API ---
META_ACCESS_TOKEN=___PASTE_META_TOKEN_HERE___
META_APP_ID=___PASTE_META_APP_ID_HERE___
META_APP_SECRET=___PASTE_META_APP_SECRET_HERE___

# --- Keitaro ---
KEITARO_API_KEY=___PASTE_KEITARO_KEY_HERE___
KEITARO_URL=___PASTE_KEITARO_URL_HERE___

# --- Asana ---
ASANA_ACCESS_TOKEN=___PASTE_ASANA_TOKEN_HERE___
ASANA_WORKSPACE_GID=___PASTE_ASANA_WORKSPACE_HERE___
ASANA_PROJECT_GID=___PASTE_ASANA_PROJECT_HERE___

# --- API / Web ---
API_HOST=0.0.0.0
API_PORT=8080
WEBHOOK_URL=___PASTE_WEBHOOK_URL_HERE___
WEBHOOK_SECRET=___PASTE_WEBHOOK_SECRET_HERE___
JWT_SECRET=___PASTE_JWT_SECRET_HERE___

# --- Logging ---
LOG_LEVEL=INFO
